YOUTUBE_API_KEY=your_youtube_api_key

# Optional SQLite fallback for local development.
KARAOKE_DB_PATH=/Users/yourname/PycharmProjects/GMs-Kareoke/karaoke.db

# Optional Supabase configuration. When SUPABASE_URL and one key are set,
# the app reads songs and leaderboard data from Supabase.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_SONGS_TABLE=songs
SUPABASE_LEADERBOARD_TABLE=leaderboard_entries

# Optional mobile queue target used to render the QR code panel.
MOBILE_QUEUE_URL=https://your-mobile-queue-app.example.com
